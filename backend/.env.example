# Valeurs par defaut pour le conteneur Docker local (docker-compose.yml) :
DB_URL=jdbc:postgresql://localhost:5432/nom_de_la_base
DB_USERNAME=utilisateur
DB_PASSWORD=motdepasse
JWT_SECRET=<generate a random 256-bit+ secret, e.g. `openssl rand -base64 64`>

# En prod, pointer DB_URL/DB_USERNAME/DB_PASSWORD vers la vraie base (ex: Neon) au lieu de Docker.
